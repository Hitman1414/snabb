{
  "expo": {
    "name": "Snabb",
    "slug": "snabb-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "jsEngine": "hermes",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FF6B35"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.snabb.mobile",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Snabb needs access to your camera to upload photos for your asks.",
        "NSPhotoLibraryUsageDescription": "Snabb needs access to your photos to upload images for your asks.",
        "NSLocationWhenInUseUsageDescription": "Snabb uses your location to show nearby services and filter asks by location.",
        "UIBackgroundModes": []
      },
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FF6B35"
      },
      "package": "com.snabb.mobile",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-build-properties",
      "expo-font",
      "expo-secure-store",
      "expo-web-browser"
    ],
    "extra": {
      "eas": {
        "projectId": "0aa5492d-5015-4970-aa21-0e83b9552e16"
      }
    },
    "owner": "prateek1414"
  }
}
