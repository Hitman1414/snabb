{
    "cli": {
        "version": ">= 7.0.0"
    },
    "build": {
        "development": {
            "developmentClient": true,
            "distribution": "internal",
            "env": {
                "EXPO_PUBLIC_API_URL": "http://localhost:8000"
            }
        },
        "preview": {
            "distribution": "internal",
            "android": {
                "buildType": "apk"
            },
            "env": {
                "EXPO_PUBLIC_API_URL": "https://snabb-backend.onrender.com"
            }
        },
        "production": {
            "distribution": "store",
            "env": {
                "EXPO_PUBLIC_API_URL": "https://snabb-backend.onrender.com"
            }
        }
    },
    "submit": {
        "production": {}
    }
}