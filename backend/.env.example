# ─── Core ─────────────────────────────────────────────────────────────────────
APP_NAME=Snabb API
APP_VERSION=1.0.0
# IMPORTANT: DEBUG=True triggers Base.metadata.create_all() on startup, which
# can silently alter a Postgres schema. Keep this False unless you're pointed
# at a local SQLite file.
DEBUG=false

# ─── Database ─────────────────────────────────────────────────────────────────
# Local dev: SQLite (auto-created)
DATABASE_URL=sqlite:///./snabb.db
# Production: Postgres / Supabase
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# ─── Security ─────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_THIS_TO_A_RANDOM_64_CHAR_HEX_STRING
ALGORITHM=HS256
# 60 minutes — short-lived JWTs limit blast radius of token theft (audit #11)
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ─── Redis Cache ──────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_ENABLED=false
CACHE_TTL=300

# ─── CORS ─────────────────────────────────────────────────────────────────────
# IMPORTANT: never use "*" with credentials. List explicit origins.
CORS_ORIGINS=["http://localhost:3000","http://localhost:8081","http://localhost:19006"]

# ─── Storage (images) ─────────────────────────────────────────────────────────
# Use "s3" in production so images persist across deploys.
STORAGE_PROVIDER=local
# IMAGE_CDN_URL=https://your-cdn.com
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION_NAME=us-east-1
# AWS_BUCKET_NAME=snabb-uploads-bucket

# Upload limits (audit #13, #16)
MAX_IMAGES_PER_ASK=5
MAX_IMAGE_SIZE_MB=5

# ─── AI ───────────────────────────────────────────────────────────────────────
# GEMINI_API_KEY=
# OPENAI_API_KEY=

# ─── Email (OTP delivery via Resend) ──────────────────────────────────────────
# When unset, OTP codes print to the application log (dev fallback).
# RESEND_API_KEY=re_...
# OTP_FROM_EMAIL="Snabb <noreply@yourdomain.com>"

# ─── Payments / Stripe ────────────────────────────────────────────────────────
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_PUBLIC_KEY=pk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
CURRENCY=usd
# Audit #10: escrow uses authorization-only (manual capture). Funds are held
# until the asker closes the ask, then captured. Set to "automatic" to disable.
PAYMENTS_CAPTURE_METHOD=manual

# ─── Monitoring ───────────────────────────────────────────────────────────────
# SENTRY_DSN=
SENTRY_ENVIRONMENT=production
# Audit #19: keep sample rates low in prod — 1.0 = 100% trace sampling.
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1

# ─── Rate Limiting (audit #18) ────────────────────────────────────────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60
# Tighter limit on auth endpoints to slow credential stuffing.
RATE_LIMIT_AUTH_PER_MINUTE=5
